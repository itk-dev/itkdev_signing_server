# OS2Forms Signing Webapp Configuration
# Copy this file to config/application.yaml and update the values.

spring:
  servlet:
    multipart:
      max-file-size: 50MB
      max-request-size: 50MB

server:
  port: 8088
  tomcat:
    max-http-form-post-size: 500000000
    max-swallow-size: 500000000
    connection-timeout: 300000

# NemLog-In Signing SDK configuration
# Test environment:
#   signing-client-url: https://underskrift.test-nemlog-in.dk/
#   validation-service-url: https://validering.test-nemlog-in.dk/api/validate
# Production environment:
#   signing-client-url: https://underskrift.nemlog-in.dk/
#   validation-service-url: https://validering.nemlog-in.dk/api/validate
nemlogin:
  signing:
    signing-client-url: https://underskrift.test-nemlog-in.dk/
    validation-service-url: https://validering.test-nemlog-in.dk/api/validate
    # Your entity ID registered with NemLog-In
    entity-id: YOUR_ENTITY_ID
    # Path to your OCES3 certificate (PKCS12 format)
    keystore-path: /app/config/certificate.p12
    # Key pair alias in the keystore
    key-pair-alias: YOUR_ALIAS
    # Keystore password
    keystore-password: YOUR_PASSWORD
    # Private key password
    private-key-password: YOUR_PASSWORD

# Application configuration
itkdev:
  # Salt used for SHA-1 hash validation of forward URLs.
  # Must match the salt configured in the calling application.
  hash-salt: YOUR_SECRET_SALT
  # List of allowed domains for external PDF URLs and forward URLs.
  # If empty, all domains are allowed (not recommended for production).
  allowed-domains:
    - example.dk
  # Directory for storing signed PDF documents
  signed-documents-dir: /app/signed-documents/
  # Directory for storing fetched source PDF documents
  source-documents-dir: /app/signers-documents/
  # Enable debug logging
  debug: false
  # Enable the /test page for manual signing verification.
  # Do NOT enable in production.
  test-page-enabled: false
